                                    "pm.test('Paging info is valid', function() {",
                                    "    const json = pm.response.json();",
                                    "    const paging = json.data.paging;",
                                    "    ",
                                    "    pm.expect(paging).to.have.property('pageIndex');",
                                    "    pm.expect(paging).to.have.property('pageSize');",
                                    "    pm.expect(paging).to.have.property('totalItems');",
                                    "    pm.expect(paging).to.have.property('totalPages');",
                                    "    ",
                                    "    pm.expect(paging.pageIndex).to.be.a('number');",
                                    "    pm.expect(paging.pageSize).to.be.a('number');",
                                    "    pm.expect(paging.totalItems).to.be.a('number');",
                                    "    pm.expect(paging.totalPages).to.be.a('number');",
                                    "    ",
                                    "    pm.expect(paging.pageIndex).to.be.at.least(1);",
                                    "    pm.expect(paging.pageSize).to.be.at.least(1);",
                                    "    pm.expect(paging.totalItems).to.be.at.least(0);",

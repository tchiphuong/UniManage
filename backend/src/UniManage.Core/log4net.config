<?xml version="1.0" encoding="utf-8" ?>
<log4net>
  <!-- 
    log4net Configuration for UniManage
    Log theo ngày và theo API như yêu cầu trong copilot-instructions.md
  -->

  <!-- Root Logger -->
  <root>
    <level value="ALL" />
    <appender-ref ref="SiftingAppender" />
    <appender-ref ref="ErrorSiftingAppender" />
    <appender-ref ref="ConsoleAppender" />
  </root>

  <!-- Console Appender (cho development) -->
  <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level [%property{cid}] [%property{user}] %logger - %message%newline" />
    </layout>
  </appender>

  <!-- Sifting Appender - Log theo ngày và theo API -->
  <appender name="SiftingAppender" type="log4net.Appender.SiftingAppender">
    <sift>
      <key value="api" />
      <default value="general" />
    </sift>
    <appender type="log4net.Appender.RollingFileAppender">
      <file type="log4net.Util.PatternString">
        <conversionPattern value="logs/%date{yyyy-MM-dd}/%property{api}.log" />
      </file>
      <appendToFile value="true" />
      <rollingStyle value="Date" />
      <datePattern value="yyyy-MM-dd" />
      <staticLogFileName value="false" />
      <preserveLogFileNameExtension value="true" />
      <maxSizeRollBackups value="30" />
      <maximumFileSize value="10MB" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level [cid:%property{cid}] [user:%property{user}] [method:%property{method}] [path:%property{path}] [status:%property{status}] [ms:%property{ms}] %logger - %message%newline" />
      </layout>
      <filter type="log4net.Filter.LevelRangeFilter">
        <levelMin value="INFO" />
        <levelMax value="FATAL" />
      </filter>
    </appender>
  </appender>

  <!-- Error Sifting Appender - Log ERROR theo ngày và theo API -->
  <appender name="ErrorSiftingAppender" type="log4net.Appender.SiftingAppender">
    <sift>
      <key value="api" />
      <default value="general" />
    </sift>
    <appender type="log4net.Appender.RollingFileAppender">
      <file type="log4net.Util.PatternString">
        <conversionPattern value="logs/%date{yyyy-MM-dd}/error-%property{api}.log" />
      </file>
      <appendToFile value="true" />
      <rollingStyle value="Date" />
      <datePattern value="yyyy-MM-dd" />
      <staticLogFileName value="false" />
      <preserveLogFileNameExtension value="true" />
      <maxSizeRollBackups value="30" />
      <maximumFileSize value="10MB" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level [cid:%property{cid}] [user:%property{user}] [method:%property{method}] [path:%property{path}] [status:%property{status}] [ms:%property{ms}] %logger - %message%newline%exception" />
      </layout>
      <filter type="log4net.Filter.LevelRangeFilter">
        <levelMin value="ERROR" />
        <levelMax value="FATAL" />
      </filter>
    </appender>
  </appender>

</log4net>

<log4net>
  <!-- 
    log4net Configuration for UniManage
    Fallback: Log theo ngày (consolidated) do SiftingAppender không khả dụng trong bản này
  -->

  <!-- Root Logger -->
  <root>
    <level value="ALL" />
    <appender-ref ref="RollingLogFileAppender" />
    <appender-ref ref="ConsoleAppender" />
  </root>

  <!-- Console Appender -->
  <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level %logger - %message%newline" />
    </layout>
  </appender>

  <!-- Rolling File Appender - Log all APIs to one file per day -->
  <appender name="RollingLogFileAppender" type="log4net.Appender.RollingFileAppender">
    <file type="log4net.Util.PatternString" value="%property{LogPath}/%date{yyyy-MM-dd}/api-trace.log" />
    <appendToFile value="true" />
    <rollingStyle value="Date" />
    <datePattern value="yyyy-MM-dd" />
    <staticLogFileName value="true" />
    <preserveLogFileNameExtension value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level [api:%property{api}] [cid:%property{cid}] [user:%property{user}] [method:%property{method}] [path:%property{path}] [status:%property{status}] [ms:%property{ms}] %message%newline%exception" />
    </layout>
  </appender>

</log4net>

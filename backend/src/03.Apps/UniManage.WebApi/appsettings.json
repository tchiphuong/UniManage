{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Server": "TCPHUONG\\SQLEXPRESS",
    "DefaultDatabase": "UniManage",
    "LogDatabase": "UniManageLog",
    "UserId": "uni_manager",
    "Password": "uni_manager@2024",
    "TrustServerCertificate": true,
    "MultipleActiveResultSets": true,
    "ConnectionTimeout": 30
  },
  "AppSettings": {
    "ApplicationName": "UniManage",
    "Version": "1.0.0",
    "Environment": "Production",
    "LogPath": "D:\\Coding\\dot_NET\\UniManage\\backend\\logs"
  },
  "IdentityServer": {
    "Authority": "https://identity.unimanage.com",
    "RequireHttpsMetadata": true,
    "ApiName": "UniManage.Api",
    "ClientId": "unimanage-client",
    "ClientSecret": "unimanage-secret",
    "Scope": "UniManage.Api offline_access",
    "RsaPrivateKeyPem": ""
  },
  "SocialAuth": {
    "GoogleClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "FacebookAppId": "YOUR_FACEBOOK_APP_ID",
    "InternalSecret": "UniManage_VERY_SECURE_SECRET_CHANGE_ME_ON_PROD"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://unimanage.com",
      "https://identity.unimanage.com"
    ]
  },
  "Swagger": {
    "Enabled": false
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "UniManage:",
    "DefaultTTLMinutes": 10,
    "Enabled": true
  },
  "FileSettings": {
    "UploadPath": "uploads",
    "TempPath": "temp",
    "FolderDateFormat": "yyyy/MM/dd",
    "AllowedImages": ".jpg,.jpeg,.png,.gif,.bmp,.webp",
    "MaxImageSizeKB": 5120,
    "AllowedDocuments": ".pdf,.doc,.docx,.xls,.xlsx,.txt",
    "MaxDocumentSizeKB": 10240,
    "AllowedVideos": ".mp4,.mov,.avi",
    "MaxVideoSizeKB": 102400,
    "MaxVideoDurationSeconds": 60,
    "AllowedAudios": ".mp3,.wav",
    "MaxAudioSizeKB": 20480
  }
}
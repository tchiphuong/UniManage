      "item": [
        {
          "name": "TC_AUTH_01: Login Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"deviceType\": \"Web\"\n}"
            },
            "url": {
              "raw": "http://localhost:60944/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "60944",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },

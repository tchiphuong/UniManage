# Ignore Visual Studio specific files
.vs/
*.user
*.suo
*.ntvs*
*.njsproj
*.sln.docstates
*.sln.DotSettings.user
*.slnLaunch.user

# Ignore build output
bin/
obj/
**/Properties/launchSettings.json

# Ignore NuGet packages (using PackageReference)
packages/
*.nupkg
*.snupkg

# Ignore dependencies and packages
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore Frontend build outputs
frontend/build/
frontend/dist/
frontend/.next/
frontend/out/
frontend/.nuxt/
frontend/.cache/
frontend/coverage/

# Ignore logs and temp files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore environment and secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
secrets.json

# Ignore database and migration files
*.mdf
*.ldf
Migrations/

# Ignore Docker and CI/CD files
.dockerignore
Dockerfile
.docker-compose*

# Ignore Redis cache and Hangfire database
redis-data/
hangfire.db

# Ignore IIS and publish settings
publish/
*.pubxml
*.publishsettings

# Ignore Tailwind and frontend generated files
tailwind.config.js
dist/
coverage/
*.tsbuildinfo
.turbo/
.vercel/
.parcel-cache/

# Ignore JetBrains Rider / WebStorm IDE files
.idea/

# Ignore other OS-specific files
.DS_Store
Thumbs.db
/src/Core/UniManage.Resource/*.resx
/src/Core/UniManage.Resource/ResourcesGenerator.cs
/src/Core/UniManage.Core/Database/Generator/CoreLanguage.cs
/src/Core/UniManage.Core/Database/Generator/DatabaseModels.cs

.fake